package project113;

public class Person {
    protected String name;  // name of the person
    protected String id;    // identification number of the user
    protected String phoneNum;  // person's phone number
    protected Rental[] rentalHistory;  // array of the rented vehicle
    protected static int rentalCount;
    public Person(String name,  String id,  String phoneNum) {// constructor
        this.name = name;
        this.id = id;
        this.phoneNum = phoneNum ;
        rentalCount=0;
        
    }
    public Person() {  // default constructor
    	this.name="undefined";
    	this.id="undefined";
    	this.phoneNum="undefined";
    }
     // getters and setters
    public String getName() {
        return name;
    }

   

    public String getId() {
        return id;
    }

   

    public String getPhoneNum() {
        return phoneNum;
    }

    public void setName(String name) {
        this.name = name;
    }

   

    public void setId(String id) {
        this.id = id;
    }

    

    public void setPhoneNum(String phoneNum) {
        this.phoneNum = phoneNum;
    }

    @Override
    public String toString() {
        return "Name: " + name + ", ID: " + id + ", Phone: " + phoneNum;
    }
}
