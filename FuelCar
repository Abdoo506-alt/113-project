
public class FuelCar extends Car {

	private double fuelTankCapacity;//: value attributes of the fuel Tank  Capacity
	private String fuelType;//: value attributes of the fuel Type
	public FuelCar(String Brand, String Model, int year, String colour, boolean AvailabilityStatus,double pricePerDay, int numberOfDoors,
			boolean insuranceIncluded, double fuelTankCapacity, String fuelType) {//: Constructor.
		
		super(Brand, Model, year, colour, AvailabilityStatus,pricePerDay, numberOfDoors, insuranceIncluded);
		this.fuelTankCapacity = fuelTankCapacity;
		this.fuelType = fuelType;
	}
	public FuelCar() {
		super();
		this.fuelTankCapacity=0;
		this.fuelType="";
	}
	
	// ↓ GETTERS & SETTERS OF THE ATTRUBUTES ↓.

	public double calculateRentalCost(int days) {//:return th cost per day  with the price of the gasoline initially present in the car
	    double cost = super.calculateRentalCost(days);
	    cost += fuelTankCapacity * 1.5; 
	    return cost;
	}
	

	public double getFuelTankCapacity() {
		return fuelTankCapacity;
	}

	public void setFuelTankCapacity(double fuelTankCapacity) {
		this.fuelTankCapacity = fuelTankCapacity;
	}

	public String getFuelType() {
		return fuelType;
	}

	public void setFuelType(String fuelType) {
		this.fuelType = fuelType;
	}
	
	
	
	}
