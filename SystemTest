    public static void userMenu(Scanner input, Admin admin, User user) {
        int choice;
        Rental lastRental = null;

        do {
            System.out.println("\n========== User Menu ==========");
            System.out.println("1. Display available vehicles");
            System.out.println("2. Search vehicle");
            System.out.println("3. Rent vehicle");
            System.out.println("4. Extend rental");
            System.out.println("5. Return vehicle");
            System.out.println("6. View rental history");
            System.out.println("0. Back to main menu");
            System.out.print("Enter choice: ");
            choice = input.nextInt();
            input.nextLine();

            switch (choice) {
                case 1:
                    admin.displayVehicles();
                    break;

                case 2:
                    System.out.print("Enter brand or model: ");
                    String keyword = input.nextLine();
                    Vehicle foundVehicle = admin.searchVehicle(keyword);
                    if (foundVehicle != null) {
                        System.out.println("Vehicle found:");
                        System.out.println(foundVehicle);
                    } else {
                        System.out.println("Vehicle not found.");
                    }
                    break;

                case 3:
                    System.out.print("Enter vehicle model to rent: ");
                    String model = input.nextLine();
                    Vehicle vehicle = admin.searchVehicle(model);

                    if (vehicle != null && vehicle.isRentable()) {
                        System.out.print("Enter number of rental days: ");
                        int daysVehicle = input.nextInt();
                        input.nextLine();
                        Accessory accessory = null;
                       
                        

                        lastRental = user.rentVehicle(vehicle, daysVehicle, accessory);

                        if (lastRental != null) {
                            Payment payment = new Payment(lastRental.totalPrice());
                            payment.processPayment();
                            System.out.println("Rental completed successfully.");
                            System.out.println(lastRental);
                        } else {
                            System.out.println("Rental failed.");
                        }
                    } else {
                        System.out.println("Vehicle unavailable or not found.");
                    }
                    break;

                case 4:
                    if (lastRental != null && lastRental.getStatus().equalsIgnoreCase("Active")) {
                        System.out.print("Enter extra days: ");
                        int extraDays = input.nextInt();
                        input.nextLine();
                        user.extendPeriod(lastRental, extraDays);
                        System.out.println("Rental extended successfully.");
                        System.out.println(lastRental);
                    } else {
                        System.out.println("No active rental found.");
                    }
                    break;

                case 5:
                    if (lastRental != null && lastRental.getStatus().equalsIgnoreCase("Active")) {
                        user.returnVehicle(lastRental);
                        System.out.println("Vehicle returned successfully.");
                        System.out.println(lastRental);
                    } else {
                        System.out.println("No active rental found.");
                    }
                    break;

                case 6:
                    user.viewRentalHistory();
                    break;

                case 0:
                    System.out.println("Returning to main menu...");
                    break;

                default:
                    System.out.println("Invalid choice.");
            }

        } while (choice != 0);
    }

  
