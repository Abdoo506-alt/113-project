
public class Payment {
    private double amount;// amount of payment
    public Payment( double amount) {//constructor
       
        this.amount = amount;
    }

    public void processPayment() { // payment process
        System.out.println("Payment processed successfully.");
        System.out.println("Payment Method: Online, Amount: " + amount);
    }

    // getter 
    public double getAmount() {
        return amount;
    }
} 
